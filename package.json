{
  "name": "pretty-gd-vs",
  "displayName": "pretty.gd for VS Code",
  "description": "A formatter for GDScript that just works!",
  "type": "commonjs",
  "icon": "images/pretty.png",
  "version": "2.0.5",
  "publisher": "poeticAndroid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poeticAndroid/pretty-gd-vs.git"
  },
  "bugs": {
    "url": "https://github.com/poeticAndroid/pretty-gd-vs/issues"
  },
  "homepage": "https://github.com/poeticAndroid/pretty-gd-vs#readme",
  "engines": {
    "vscode": "^1.112.0"
  },
  "categories": [
    "Formatters",
    "Programming Languages"
  ],
  "main": "./extension.cjs",
  "contributes": {
    "languages": [
      {
        "id": "gdscript",
        "aliases": [
          "GDScript",
          "gdscript"
        ],
        "extensions": [
          ".gd"
        ],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "dependencies": {
    "pretty-gd-js": "^2.0.5"
  }
}